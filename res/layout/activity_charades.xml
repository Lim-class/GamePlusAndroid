<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#2C3E50"
    android:padding="20dp">

    <TextView
        android:id="@+id/tvTitolo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:text="MIMA QUESTA AZIONE:"
        android:textColor="#ECF0F1"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvAzioneDaMimare"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:gravity="center"
        android:text="CORRERE"
        android:textColor="#E67E22"
        android:textSize="50sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/btnSuccessivoMimo"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:layout_alignParentBottom="true"
        android:backgroundTint="#E67E22"
        android:text="FATTO! PROSSIMO MIMO"
        android:textColor="#FFFFFF"
        android:textSize="18sp" />

</RelativeLayout>