<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#FAFAFA">

    <TextView
        android:id="@+id/tvTitoloLega"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Gestione Personaggi"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#002D57"
        android:layout_marginBottom="10dp"/>

    <Button
        android:id="@+id/btnVaiAlMercato"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="VAI AL MERCATO (GIOCA)"
        android:backgroundTint="#002D57"
        android:layout_marginBottom="10dp"/>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"
        app:cardCornerRadius="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <EditText
                android:id="@+id/etNomePersonaggio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Nome Personaggio (es. Guerriero)"/>

            <EditText
                android:id="@+id/etValorePersonaggio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Valore/Prezzo base"
                android:inputType="number"
                android:layout_marginTop="8dp"/>

            <Button
                android:id="@+id/btnAggiungiPersonaggio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="AGGIUNGI AL LISTINO"
                android:layout_marginTop="12dp"
                android:backgroundTint="#66CCB3"
                android:textColor="#002D57"
                android:textStyle="bold"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Listino (Tocca un personaggio per assegnare punti):"
        android:textStyle="bold"
        android:layout_marginTop="4dp"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvPersonaggi"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="8dp"/>

    <Button
        android:id="@+id/btnConcludiGiornata"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="CONCLUDI GIORNATA E SALVA"
        android:backgroundTint="#FF9800"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:layout_marginTop="8dp"/>

    <Button
        android:id="@+id/btnEliminaLega"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="ELIMINA LEGA DEFINITIVAMENTE"
        android:backgroundTint="#D32F2F"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:layout_marginTop="4dp"/>

</LinearLayout>