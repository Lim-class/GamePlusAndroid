<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#1A1A2E"
    android:padding="24dp">

    <TextView
        android:id="@+id/status_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Turno di X"
        android:textColor="#E94560"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginBottom="24dp"/>

    <androidx.cardview.widget.CardView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:cardCornerRadius="12dp"
        app:cardBackgroundColor="#16213E"
        android:layout_marginBottom="32dp">

        <Spinner
            android:id="@+id/spinner_difficolta"
            android:layout_width="220dp"
            android:layout_height="48dp"
            android:entries="@array/livelli_tris"
            android:theme="@style/ThemeOverlay.AppCompat.Dark" />
    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:cardCornerRadius="16dp"
        app:cardElevation="10dp"
        app:cardBackgroundColor="#0F3460">

        <GridLayout
            android:id="@+id/grid_layout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:columnCount="3"
            android:rowCount="3"
            android:padding="12dp">

            <Button android:id="@+id/btn_0" style="@style/TrisButtonStyle" />
            <Button android:id="@+id/btn_1" style="@style/TrisButtonStyle" />
            <Button android:id="@+id/btn_2" style="@style/TrisButtonStyle" />
            <Button android:id="@+id/btn_3" style="@style/TrisButtonStyle" />
            <Button android:id="@+id/btn_4" style="@style/TrisButtonStyle" />
            <Button android:id="@+id/btn_5" style="@style/TrisButtonStyle" />
            <Button android:id="@+id/btn_6" style="@style/TrisButtonStyle" />
            <Button android:id="@+id/btn_7" style="@style/TrisButtonStyle" />
            <Button android:id="@+id/btn_8" style="@style/TrisButtonStyle" />

        </GridLayout>
    </androidx.cardview.widget.CardView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_reset"
        android:layout_width="200dp"
        android:layout_height="60dp"
        android:text="Ricomincia"
        android:layout_marginTop="40dp"
        app:cornerRadius="30dp"
        android:backgroundTint="#E94560"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        app:icon="@android:drawable/ic_menu_rotate"
        app:iconGravity="textStart"/>

</LinearLayout>