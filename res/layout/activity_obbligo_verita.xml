<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#2C3E50"
    android:gravity="center_horizontal">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SCEGLI MODALITÀ"
        android:textSize="28sp"
        android:textColor="#ECF0F1"
        android:textStyle="bold"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="40dp"/>

    <Button
        android:id="@+id/btn_mode_classic"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:text="CLASSICO (Soft)"
        android:backgroundTint="#2ECC71"
        android:layout_marginBottom="20dp"/>

    <Button
        android:id="@+id/btn_mode_party"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:text="PARTY (Divertente)"
        android:backgroundTint="#F1C40F"
        android:textColor="#000000"
        android:layout_marginBottom="20dp"/>

    <Button
        android:id="@+id/btn_mode_hard"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:text="ESTREMO "
        android:backgroundTint="#E74C3C"
        android:layout_marginBottom="20dp"/>

</LinearLayout>