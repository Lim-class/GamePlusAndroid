<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvNomeLegaDettaglio"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nome Lega"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#002D57" />

        <TextView
            android:id="@+id/tvCreditiLegaDettaglio"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Crediti iniziali: 500"
            android:textSize="16sp"
            android:textColor="#66CCB3"
            android:layout_marginBottom="10dp" />

        <TextView
            android:id="@+id/tvInfoModalita"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Modalità: Caricamento..."
            android:textSize="14sp"
            android:textStyle="italic"
            android:textColor="#757575"
            android:layout_marginBottom="10dp" />

        <TextView
            android:id="@+id/tvStatoMercato"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Stato Mercato: Calcolo in corso..."
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#E53935"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/tvInfoCalcolo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Classifica aggiornata il: -- alle --"
            android:textSize="13sp"
            android:textColor="#555555"
            android:layout_marginBottom="20dp"/>

        <Button
            android:id="@+id/btnVediClassifica"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="VEDI CLASSIFICA GENERALE"
            android:backgroundTint="#66CCB3"
            android:layout_marginBottom="10dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mercato Personaggi"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvPersonaggiMercato"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

    </LinearLayout>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabMiaSquadra"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        app:backgroundTint="#002D57"
        app:srcCompat="@android:drawable/ic_menu_myplaces"
        app:tint="#FFFFFF" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>