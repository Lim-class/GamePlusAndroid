<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A2E"
    android:padding="24dp">

    <TextView
        android:id="@+id/txt_titolo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="IMPICCATO"
        android:textColor="#E94560"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/txt_errori"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Vite: ❤️ ❤️ ❤️ ❤️ ❤️ ❤️"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/txt_titolo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.cardview.widget.CardView
        android:id="@+id/card_image"
        android:layout_width="0dp"
        android:layout_height="200dp"
        android:layout_marginTop="24dp"
        app:cardBackgroundColor="#16213E"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp"
        app:layout_constraintTop_toBottomOf="@id/txt_errori"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/img_impiccato"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="20dp"
            android:src="@android:drawable/ic_menu_help"
            android:contentDescription="Stato gioco" />
    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/txt_parola_nascosta"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="_ _ _ _ _"
        android:textColor="#00D2FF"
        android:textSize="36sp"
        android:textStyle="bold"
        android:letterSpacing="0.2"
        app:layout_constraintTop_toBottomOf="@id/card_image"
        app:layout_constraintBottom_toTopOf="@id/layout_input"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/layout_input"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="32dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <EditText
            android:id="@+id/edit_lettera"
            android:layout_width="80dp"
            android:layout_height="60dp"
            android:background="@drawable/shape_input"
            android:hint="A"
            android:textColorHint="#555"
            android:inputType="textCapCharacters"
            android:maxLength="1"
            android:textAlignment="center"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:layout_marginEnd="16dp"/>

        <Button
            android:id="@+id/btn_tenta"
            android:layout_width="wrap_content"
            android:layout_height="60dp"
            android:text="PROVA"
            android:paddingHorizontal="32dp"
            android:backgroundTint="#E94560"
            android:textColor="#FFFFFF"
            app:cornerRadius="12dp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>