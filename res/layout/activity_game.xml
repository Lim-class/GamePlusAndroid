<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#1B2631">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#2E4053"
            app:cardCornerRadius="15dp"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2">
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/lbl_liquidita"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Liquidità"
                            android:textColor="#BDC3C7"
                            android:textSize="12sp"/>

                        <TextView
                            android:id="@+id/txt_liquidita"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="10.000 €"
                            android:textColor="#52BE80"
                            android:textSize="18sp"
                            android:textStyle="bold"/>
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="end">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tasse Pagate" android:textColor="#BDC3C7" android:textSize="12sp"/>
                        <TextView android:id="@+id/txt_tasse_pagate" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0 €" android:textColor="#E74C3C" android:textSize="18sp" android:textStyle="bold"/>
                    </LinearLayout>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#566573" android:layout_marginVertical="10dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Valore Portafoglio" android:textColor="#BDC3C7" android:textSize="12sp"/>
                <TextView android:id="@+id/txt_valore_portafoglio" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0 €" android:textColor="#F4D03F" android:textSize="22sp" android:textStyle="bold"/>

                <Button android:id="@+id/btn_dettaglio_portafoglio" android:layout_width="wrap_content" android:layout_height="35dp" android:text="Analisi Asset" android:textSize="12sp" android:backgroundTint="#5D6D7E" android:layout_marginTop="10dp"/>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#566573" android:layout_marginVertical="10dp"/>

                <TextView android:id="@+id/txt_stipendio" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Lavoro: Disoccupato" android:textColor="#5DADE2" android:textSize="15sp"/>
                <TextView android:id="@+id/txt_eta" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Età: 18 anni" android:textColor="#ECF0F1" android:layout_marginTop="5dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <Button
            android:id="@+id/btn_cerca_lavoro"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="LAVORA (Passa 6 Mesi)"
            android:backgroundTint="#2980B9"
            android:textStyle="bold"
            android:layout_marginBottom="15dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#212F3C"
            app:cardCornerRadius="10dp"
            android:layout_marginBottom="15dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="15dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="MERCATO FINANZIARIO"
                    android:textColor="#F39C12"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:layout_marginBottom="10dp"/>

                <Spinner
                    android:id="@+id/spinner_strumenti_finanziari"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:backgroundTint="#FFFFFF"
                    android:layout_marginBottom="5dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="5dp">
                    <TextView
                        android:id="@+id/txt_asset_prezzo"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Prezzo: 0€"
                        android:textColor="#52BE80"
                        android:textSize="14sp"/>
                    <TextView
                        android:id="@+id/txt_asset_posseduti"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Portafoglio: 0"
                        android:gravity="end"
                        android:textColor="#ECF0F1"
                        android:textSize="14sp"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/txt_max_acquistabili"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Max acquistabili: 0"
                    android:textColor="#85929E"
                    android:textSize="12sp"
                    android:gravity="end"
                    android:layout_marginBottom="5dp"/>

                <EditText
                    android:id="@+id/edit_quantita_asset"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Quantità da scambiare"
                    android:inputType="number"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#7F8C8D"
                    android:backgroundTint="#BDC3C7"
                    android:layout_marginBottom="10dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2">
                    <Button
                        android:id="@+id/btn_investi_asset"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="COMPRA"
                        android:backgroundTint="#27AE60"
                        android:layout_marginEnd="5dp"/>
                    <Button
                        android:id="@+id/btn_vendi_asset"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="VENDI"
                        android:backgroundTint="#C0392B"
                        android:layout_marginStart="5dp"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <Button
            android:id="@+id/btn_startup"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="FONDA STARTUP (50k€)"
            android:backgroundTint="#8E44AD"
            android:textSize="13sp"
            android:layout_marginBottom="8dp"/>

    </LinearLayout>
</ScrollView>